<screen name="Imagesdownloader" position="0,0" size="1920,1080" backgroundColor="transparent" flags="wfNoBorder">

    <!-- Background -->
    <ePixmap position="0,0" zPosition="-1" size="1920,1080"
        pixmap="/usr/lib/enigma2/python/Plugins/Extensions/ElieSatPanelGrid/assets/background/panel_bg.jpg"/>

    <!-- Header -->
    <eLabel position="0,0" size="1920,130" zPosition="10" backgroundColor="#000000"/>
    <eLabel text="● Images Downloader – Feeds: OpenSPA, OpenATV, OpenHDF, OpenViX, OpenPLI, OpenblackHole ....."
        position="350,0" size="1600,50" zPosition="11"
        font="Bold;32" halign="left" valign="center"
        foregroundColor="#E6BE3A" backgroundColor="#000000"/>

    <!-- LIST (10 rows exactly) -->
    <widget name="list"
        position="48,170"
        size="1240,660"
        scrollbarMode="showOnDemand"
        font="Regular;35"
        render="Listbox"
        itemHeight="66"
        selectionPixmap="/usr/lib/enigma2/python/Plugins/Extensions/ElieSatPanelGrid/assets/icon/selection.png"
        foregroundColor="#E6BE3A"
        transparent="1"/>

    <!-- Item / Download -->
    <widget name="item_name"
        position="0,840"
        size="1920,60"
        zPosition="12"
        font="Bold;36"
        halign="center"
        valign="center"
        foregroundColor="#E6BE3A"
        backgroundColor="#000000"
        transparent="1"/>

    <widget name="download_info"
        position="0,900"
        size="1920,50"
        zPosition="12"
        font="Bold;32"
        halign="center"
        valign="center"
        foregroundColor="#E6BE3A"
        backgroundColor="#000000"
        transparent="1"/>

    <!-- Progress -->
    <widget name="progress"
        position="0,950"
        size="1920,40"
        zPosition="12"
        foregroundColor="#E6BE3A"
        backgroundColor="#000000"/>

    <!-- System info -->
    <widget name="image_name" position="1470,420" size="500,35"
        font="Bold;32" halign="left" valign="center"
        foregroundColor="#E6BE3A" transparent="1"/>

    <widget name="python_ver" position="1470,460" size="500,35"
        font="Bold;32" halign="left" valign="center"
        foregroundColor="#E6BE3A" transparent="1"/>

    <widget name="local_ip" position="1470,500" size="500,35"
        font="Bold;32" halign="left" valign="center"
        foregroundColor="#E6BE3A" transparent="1"/>

    <widget name="StorageInfo" position="1470,540" size="540,35"
        font="Bold;32" halign="left" valign="center"
        foregroundColor="#E6BE3A" transparent="1"/>

    <widget name="RAMInfo" position="1470,580" size="500,35"
        font="Bold;32" halign="left" valign="center"
        foregroundColor="#E6BE3A" transparent="1"/>

    <widget name="net_status" position="1470,620" size="500,35"
        font="Bold;32" halign="left" valign="center"
        foregroundColor="#E6BE3A" transparent="1"/>

    <widget name="device_name" position="1470,660" size="500,35"
        font="Bold;32" halign="left" valign="center"
        foregroundColor="#E6BE3A" transparent="1"/>

    <!-- Clock -->
    <widget source="global.CurrentTime" render="Label"
        position="1350,180" size="500,35"
        font="Bold;32"
        halign="center"
        valign="center"
        foregroundColor="#E6BE3A"
        transparent="1">
        <convert type="ClockToText">Format %A %d %B</convert>
    </widget>

    <widget source="global.CurrentTime" render="Label"
        position="1350,220" size="500,35"
        font="Bold;32"
        halign="center"
        valign="center"
        foregroundColor="#E6BE3A"
        transparent="1">
        <convert type="ClockToText">Format %H:%M:%S</convert>
    </widget>

    <!-- Bottom buttons -->
    <eLabel position="0,1075" size="480,5" backgroundColor="red"/>
    <widget name="red"
        position="0,1000"
        size="480,75"
        font="Bold;32"
        halign="center"
        valign="center"
        text="Cancel Download"
        foregroundColor="#E6BE3A"
        backgroundColor="#000000"/>

    <eLabel position="480,1075" size="480,5" backgroundColor="green"/>
    <widget name="green"
        position="480,1000"
        size="480,75"
        font="Bold;32"
        halign="center"
        valign="center"
        text="-"
        foregroundColor="#E6BE3A"
        backgroundColor="#000000"/>

    <eLabel position="960,1075" size="480,5" backgroundColor="#E6BE3A"/>
    <widget name="yellow"
        position="960,1000"
        size="480,75"
        font="Bold;32"
        halign="center"
        valign="center"
        text="-"
        foregroundColor="#E6BE3A"
        backgroundColor="#000000"/>

    <eLabel position="1440,1075" size="480,5" backgroundColor="blue"/>
    <widget name="blue"
        position="1440,1000"
        size="480,75"
        font="Bold;32"
        halign="center"
        valign="center"
        text="-"
        foregroundColor="#E6BE3A"
        backgroundColor="#000000"/>

    <!-- Device icon -->
    <widget name="device_icon"
        position="1300,720"
        size="600,200"
        transparent="1"
        alphatest="blend"/>

    <!-- Side bars -->
    <eLabel position="0,130" size="80,870" backgroundColor="#000000"/>
    <eLabel position="1840,130" size="80,870" backgroundColor="#000000"/>

    <widget name="left_bar"
        position="10,160"
        size="60,760"
        font="Regular;26"
        halign="center"
        valign="top"
        backgroundColor="#000000"
        foregroundColor="#E6BE3A"
        transparent="1"
        noWrap="1"/>

    <widget name="right_bar"
        position="1850,160"
        size="60,760"
        font="Regular;26"
        halign="center"
        valign="top"
        backgroundColor="#000000"
        foregroundColor="#E6BE3A"
        transparent="1"
        noWrap="1"/>

 <!-- Left / Right vertical bars -->
    <widget name="left_bar" position="10,160" size="60,760" zPosition="20"
        font="Regular;26" halign="center" valign="top"
        backgroundColor="#000000"
        foregroundColor="#E6BE3A" transparent="1" noWrap="1" />
    <widget name="right_bar" position="1850,160" size="60,760" zPosition="20"
        font="Regular;26" halign="center" valign="top"
        backgroundColor="#000000"
        foregroundColor="#E6BE3A" transparent="1" noWrap="1" />
</screen>
