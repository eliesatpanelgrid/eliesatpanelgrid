<screen name="Deps" position="0,0" size="1280,720" backgroundColor="transparent" flags="wfNoBorder" title="Smart Dependency Checker">

    <!-- Background -->
    <ePixmap position="0,0" zPosition="-1" size="1280,720"
        pixmap="/usr/lib/enigma2/python/Plugins/Extensions/ElieSatPanelGrid/assets/background/panel_bg.jpg"/>

    <!-- Top black bar -->
    <eLabel position="0,0" size="1280,87" zPosition="10" backgroundColor="#000000" />

    <!-- Title -->
    <eLabel text="● Dependency Status"
        position="233,0" size="933,33" zPosition="11"
        font="Bold;22" halign="left" valign="center"
        foregroundColor="#E6BE3A" backgroundColor="#000000" />

    <!-- LIVE STATUS COUNTER -->
    <widget name="dep_status"
        position="233,47" size="933,33" zPosition="11"
        font="Bold;19" halign="left" valign="center"
        foregroundColor="#E6BE3A" backgroundColor="#000000" />

    <!-- Bottom buttons -->
    <eLabel position="0,717" size="320,3" backgroundColor="red"/>
    <widget name="red"
        position="0,667" size="320,50"
        font="Bold;22" halign="center" valign="center"
        text="Stop installation"
        foregroundColor="#E6BE3A" backgroundColor="#000000"/>

    <eLabel position="320,717" size="320,3" backgroundColor="green"/>
    <widget name="green"
        position="320,667" size="320,50"
        font="Bold;22" halign="center" valign="center"
        text="Install"
        foregroundColor="#E6BE3A" backgroundColor="#000000"/>

    <eLabel position="640,717" size="320,3" backgroundColor="#E6BE3A"/>
    <widget name="yellow"
        position="640,667" size="320,50"
        font="Bold;22" halign="center" valign="center"
        text="Show N/A"
        foregroundColor="#E6BE3A" backgroundColor="#000000"/>

    <eLabel position="960,717" size="320,3" backgroundColor="blue"/>
    <widget name="blue"
        position="960,667" size="320,50"
        font="Bold;22" halign="center" valign="center"
        text="Show All"
        foregroundColor="#E6BE3A" backgroundColor="#000000"/>

    <!-- Side bars -->
    <eLabel position="0,87" size="53,580" zPosition="10" backgroundColor="#000000" />
    <eLabel position="1200,87" size="53,580" zPosition="10" backgroundColor="#000000" />

    <!-- Deps list -->
    <widget name="deps_text"
        position="100,120" size="733,467" zPosition="12"
        font="Bold;22" halign="left" valign="top"
        foregroundColor="#E6BE3A" backgroundColor="#000000" />

    <!-- Page info -->
    <widget name="page_info"
        position="1133,627" size="133,40" zPosition="12"
        font="Bold;22" halign="left" valign="center"
        foregroundColor="#E6BE3A" backgroundColor="#000000" />

    <!-- System Info -->
    <widget name="image_name" position="980,280" size="333,23" zPosition="12"
        font="Bold;22" foregroundColor="#E6BE3A" transparent="1" />
    <widget name="python_ver" position="980,307" size="333,23" zPosition="12"
        font="Bold;22" foregroundColor="#E6BE3A" transparent="1" />
    <widget name="local_ip" position="980,333" size="333,23" zPosition="12"
        font="Bold;22" foregroundColor="#E6BE3A" transparent="1" />
    <widget name="StorageInfo" position="980,360" size="333,23" zPosition="12"
        font="Bold;22" foregroundColor="#E6BE3A" transparent="1" />
    <widget name="RAMInfo" position="980,387" size="333,23" zPosition="12"
        font="Bold;22" foregroundColor="#E6BE3A" transparent="1" />
    <widget name="net_status" position="980,413" size="333,23" zPosition="12"
        font="Bold;22" foregroundColor="#E6BE3A" transparent="1" />

    <!-- Vertical text -->
    <widget name="left_bar"
        position="7,107" size="40,507" zPosition="20"
        font="Regular;18" halign="center"
        foregroundColor="#E6BE3A" backgroundColor="#000000" />

    <widget name="right_bar"
        position="1200,107" size="40,507" zPosition="20"
        font="Regular;18" halign="center"
        foregroundColor="#E6BE3A" backgroundColor="#000000" />

    <!-- Date -->
    <widget source="global.CurrentTime" render="Label"
        position="900,120" size="333,23" zPosition="12"
        font="Bold;22" halign="center"
        foregroundColor="#E6BE3A" transparent="1">
        <convert type="ClockToText">Format %A %d %B</convert>
    </widget>

    <!-- Clock -->
    <widget source="global.CurrentTime" render="Label"
        position="900,147" size="333,23" zPosition="12"
        font="Bold;22" halign="center"
        foregroundColor="#E6BE3A" transparent="1">
        <convert type="ClockToText">Format %H:%M:%S</convert>
    </widget>

    <!-- Current installing package -->
<widget name="current_install"
    position="100,595" size="733,30" zPosition="15"
    font="Bold;22" halign="left" valign="center"
    foregroundColor="#FF8C00" backgroundColor="#000000"
    transparent="0" />

<!-- Temporary stop message -->
<widget name="stop_msg"
    position="100,625" size="733,30" zPosition="15"
    font="Bold;22" halign="left" valign="center"
    foregroundColor="#FF8C00" backgroundColor="#000000"
    transparent="0" />

</screen>
